<?xml version="1.0" encoding="utf-8"?>
<!--
  fireWTwall — ASP.NET Example Application

  This Web.config registers the WAF HttpModule so it fires on every request.
  Copy these <modules> / <httpModules> entries into your own Web.config,
  or reference the FireWTWall assembly from your project.
-->
<configuration>

  <system.web>
    <compilation debug="false" targetFramework="4.7.2" />

    <!-- IIS Classic pipeline mode -->
    <httpModules>
      <add name="FireWTWallModule" type="FireWTWall.WafHttpModule" />
    </httpModules>
  </system.web>

  <system.webServer>
    <!-- IIS Integrated pipeline mode (recommended) -->
    <modules>
      <add name="FireWTWallModule" type="FireWTWall.WafHttpModule" />
    </modules>

    <!-- Remove server identification headers -->
    <httpProtocol>
      <customHeaders>
        <remove name="X-Powered-By" />
        <remove name="X-AspNet-Version" />
      </customHeaders>
    </httpProtocol>

    <validation validateIntegratedModeConfiguration="false" />
  </system.webServer>

</configuration>
